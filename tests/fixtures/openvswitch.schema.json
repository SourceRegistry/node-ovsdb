{
  "name": "Open_vSwitch",
  "version": "8.3.1",
  "tables": {
    "Bridge": {
      "columns": {
        "name": {
          "type": "string"
        },
        "ports": {
          "type": {
            "key": {
              "type": "uuid",
              "refTable": "Port",
              "refType": "strong"
            },
            "min": 0,
            "max": "unlimited"
          }
        },
        "datapath_type": {
          "type": {
            "key": {
              "type": "string",
              "enum": [
                "set",
                [
                  "netdev",
                  "system"
                ]
              ]
            },
            "min": 0,
            "max": 1
          }
        }
      }
    },
    "Interface": {
      "columns": {
        "name": {
          "type": "string"
        },
        "options": {
          "type": {
            "key": "string",
            "value": "string",
            "min": 0,
            "max": "unlimited"
          }
        }
      }
    }
  }
}
